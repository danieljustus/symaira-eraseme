{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/danieljustus/symaira-eraseme/registry/schemas/broker.schema.json",
  "title": "Data Broker Definition",
  "description": "Schema for YAML broker files in the Symaira EraseMe registry.",
  "type": "object",
  "required": [
    "id",
    "name",
    "website",
    "category",
    "jurisdictions",
    "laws",
    "priority",
    "opt_out"
  ],
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^[a-z0-9-]+$",
      "description": "Unique identifier (lowercase, hyphenated)."
    },
    "name": {
      "type": "string",
      "description": "Full legal name of the broker."
    },
    "website": {
      "type": "string",
      "format": "uri",
      "description": "Broker homepage URL."
    },
    "category": {
      "type": "string",
      "enum": [
        "people-search",
        "marketing",
        "credit",
        "analytics",
        "background-check",
        "social-media",
        "other"
      ]
    },
    "jurisdictions": {
      "type": "array",
      "items": { "type": "string", "pattern": "^[A-Z]{2}(-[A-Z]{2})?$" },
      "minItems": 1,
      "description": "ISO country codes (e.g. DE, US, EU)."
    },
    "laws": {
      "type": "array",
      "items": {
        "type": "string",
        "enum": ["GDPR", "CCPA", "CPRA", "LGPD", "PIPEDA"]
      },
      "minItems": 1
    },
    "data_sensitivity": {
      "type": "integer",
      "minimum": 1,
      "maximum": 5,
      "default": 3,
      "description": "1–5 scale of data sensitivity."
    },
    "priority": {
      "type": "string",
      "enum": ["high", "medium", "low"]
    },
    "opt_out": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["type"],
        "oneOf": [
          {
            "properties": {
              "type": { "const": "email" },
              "endpoint": { "type": "string", "format": "email" },
              "template": { "type": "string" },
              "locale": { "type": "string", "pattern": "^[a-z]{2}(-[A-Z]{2})?$" },
              "required_fields": {
                "type": "array",
                "items": { "type": "string" }
              },
              "supports_suppression": { "type": "boolean" },
              "expected_response_days": { "type": "integer", "minimum": 1 }
            },
            "required": ["endpoint", "template", "locale"]
          },
          {
            "properties": {
              "type": { "const": "web_form" },
              "url": { "type": "string", "format": "uri" },
              "form_spec": {
                "type": "object",
                "properties": {
                  "steps": {
                    "type": "array",
                    "items": { "$ref": "#/$defs/formStep" }
                  },
                  "timeout_seconds": { "type": "number", "minimum": 1 },
                  "rate_limit_delay": { "type": "number", "minimum": 0 },
                  "headless": { "type": "boolean" }
                },
                "required": ["steps"]
              }
            },
            "required": ["url", "form_spec"]
          }
        ],
        "additionalProperties": true
      }
    },
    "verification": {
      "type": "object",
      "properties": {
        "ack_keywords": { "type": "array", "items": { "type": "string" } },
        "rejection_keywords": { "type": "array", "items": { "type": "string" } },
        "human_required_keywords": { "type": "array", "items": { "type": "string" } }
      }
    },
    "disabled": {
      "type": "boolean",
      "default": false,
      "description": "When true, this broker is excluded from default plans and listings. Use when the broker entry is incomplete or known-broken (e.g. unverified CAPTCHA sitekey). Pair with notes explaining the reason."
    },
    "added_date": {
      "type": "string",
      "format": "date",
      "description": "ISO 8601 date when this broker entry was added to the registry."
    },
    "source": {
      "type": "string",
      "description": "Source registry or reference that verified this broker (e.g. 'California Data Broker Registry 2026', 'Vermont Data Broker Registry'). Only set when the source is known and verifiable."
    },
    "status": {
      "type": "string",
      "enum": ["active", "deprecated", "merged", "out-of-business"],
      "default": "active",
      "description": "Operational status of the broker entry."
    },
    "notes": { "type": "string" }
  },
  "$defs": {
    "formStep": {
      "type": "object",
      "additionalProperties": false,
      "minProperties": 1,
      "description": "One step in a Playwright form_spec. Standard DSL: fill/select keys map CSS selector -> value (use ${field_name} template syntax to interpolate identity fields).",
      "properties": {
        "goto": { "type": "string", "description": "URL to navigate to. Use '.' for the form's own URL." },
        "fill": {
          "type": "object",
          "description": "CSS selector -> value mapping. Use ${full_name}, ${email} etc. for identity interpolation. Keys must look like CSS selectors (start with #, ., [, *, or a tag name) — the legacy {selector, from} shape is rejected.",
          "additionalProperties": { "type": "string" },
          "propertyNames": { "pattern": "[#.\\[]" },
          "minProperties": 1
        },
        "select": {
          "type": "object",
          "description": "CSS selector -> option value mapping (for <select> elements). Same key constraints as `fill`.",
          "additionalProperties": { "type": "string" },
          "propertyNames": { "pattern": "[#.\\[]" },
          "minProperties": 1
        },
        "click": { "type": "string", "description": "CSS selector to click." },
        "wait_for": { "type": "string", "description": "CSS selector to wait for." },
        "wait_seconds": { "type": "number", "minimum": 0 },
        "screenshot": { "type": "string", "description": "Screenshot file label (no extension)." },
        "assert_text": { "type": "string", "description": "Text that must appear on the page." },
        "solve_captcha": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "type": { "type": "string", "enum": ["recaptcha-v2", "recaptcha-v3", "hcaptcha", "turnstile"] },
            "site_key": { "type": "string", "minLength": 8, "description": "The CAPTCHA site key embedded in the broker's form. Must be a real key, not a placeholder." },
            "provider": { "type": "string", "enum": ["capsolver", "2captcha", "anticaptcha"] },
            "action": { "type": "string", "description": "reCAPTCHA v3 action parameter." },
            "min_score": { "type": "number", "minimum": 0, "maximum": 1, "description": "reCAPTCHA v3 minimum required score (0..1)." },
            "is_invisible": { "type": "boolean", "description": "True for invisible CAPTCHAs (hCaptcha, reCAPTCHA invisible)." }
          },
          "required": ["type", "site_key"]
        }
      }
    }
  }
}
