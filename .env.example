# Symaira EraseMe Environment Configuration
# Copy this file to .env and fill in your values.
# Symaira EraseMe reads environment variables for API keys, data paths, and consent.

# ──────────────────────────────────────────────────────────────
# LLM Provider Configuration (required for AI-powered triage)
# ──────────────────────────────────────────────────────────────

# LLM provider: anthropic, openai, or ollama (default: anthropic)
SYMERASEME_LLM_PROVIDER=anthropic

# Model name (provider-specific; omit to use provider default)
# Anthropic: claude-3-5-sonnet-latest, claude-3-5-haiku-latest, claude-3-opus-latest
# OpenAI: gpt-4o, gpt-4o-mini, gpt-4-turbo
# Ollama: llama3.1, mistral, codellama
# SYMERASEME_LLM_MODEL=claude-3-5-sonnet-latest

# Provider-specific API keys
ANTHROPIC_API_KEY=sk-ant-api03-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Ollama host (only needed when provider=ollama; default: http://localhost:11434)
OLLAMA_HOST=http://localhost:11434

# ──────────────────────────────────────────────────────────────
# CAPTCHA Solving Services (optional — choose one)
# ──────────────────────────────────────────────────────────────

# CapSolver API key for automated CAPTCHA solving
CAPSOLVER_API_KEY=CAP-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# 2Captcha API key for automated CAPTCHA solving
TWOCAPTCHA_API_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ──────────────────────────────────────────────────────────────
# Data Paths (optional — defaults to ~/.local/share/symeraseme)
# ──────────────────────────────────────────────────────────────

# Directory for the SQLite database and event store
SYMERASEME_DB_DIR=~/.local/share/symeraseme

# Directory for general application data
SYMERASEME_DATA_DIR=~/.local/share/symeraseme

# Path to the encrypted identity profile file
SYMERASEME_IDENTITY_PATH=~/.local/share/symeraseme/identity.encrypted

# Path to the Python virtual environment used by the scheduler
SYMERASEME_VENV=~/.local/share/symeraseme/venv

# ──────────────────────────────────────────────────────────────
# Consent & Security
# ──────────────────────────────────────────────────────────────

# Consent token for destructive operations (generated by `symeraseme consent`)
SYMERASEME_CONSENT=

# ──────────────────────────────────────────────────────────────
# SMTP (optional — for direct batch email sending)
# ──────────────────────────────────────────────────────────────

# SMTP connection used by the async batch email path
# (avoids spawning a Himalaya CLI subprocess per message)
SYMERASEME_SMTP_HOST=localhost
SYMERASEME_SMTP_PORT=587
SYMERASEME_SMTP_USER=
SYMERASEME_SMTP_PASSWORD=
SYMERASEME_SMTP_FROM=
# Set to 0 to disable STARTTLS (e.g. for local test servers)
SYMERASEME_SMTP_TLS=1
