# OpenEraseMe Environment Configuration
# Copy this file to .env and fill in your values.
# OpenEraseMe reads environment variables for API keys, data paths, and consent.

# ──────────────────────────────────────────────────────────────
# LLM API Keys (required for AI-powered features)
# ──────────────────────────────────────────────────────────────

# Anthropic API key for Claude-powered triage and rebuttal generation
ANTHROPIC_API_KEY=sk-ant-api03-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ──────────────────────────────────────────────────────────────
# CAPTCHA Solving Services (optional — choose one)
# ──────────────────────────────────────────────────────────────

# CapSolver API key for automated CAPTCHA solving
CAPSOLVER_API_KEY=CAP-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# 2Captcha API key for automated CAPTCHA solving
TWOCAPTCHA_API_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ──────────────────────────────────────────────────────────────
# Data Paths (optional — defaults to ~/.local/share/openeraseme)
# ──────────────────────────────────────────────────────────────

# Directory for the SQLite database and event store
OPENERASEME_DB_DIR=~/.local/share/openeraseme

# Directory for general application data
OPENERASEME_DATA_DIR=~/.local/share/openeraseme

# Path to the encrypted identity profile file
OPENERASEME_IDENTITY_PATH=~/.local/share/openeraseme/identity.encrypted

# Path to the Python virtual environment used by the scheduler
OPENERASEME_VENV=~/.local/share/openeraseme/venv

# ──────────────────────────────────────────────────────────────
# Consent & Security
# ──────────────────────────────────────────────────────────────

# Consent token for destructive operations (generated by `openeraseme consent`)
OPENERASEME_CONSENT=
